{
  "expo": {
    "name": "Size Matters",
    "slug": "size-matters",
    "owner": "westhaven-holdings",
    "scheme": "sizematters",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1623"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vibecode.reelsize.o65mr2",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.sizematters",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0B1623"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-quick-actions",
        {
          "iosActions": [
            {
              "id": "com.sizematters.feedback",
              "title": "Deleting Size Matters?",
              "subtitle": "Tell us why! We add new features every month.",
              "icon": "symbol:xmark.circle.fill"
            }
          ]
        }
      ],
      "expo-asset",
      "expo-web-browser",
      "react-native-edge-to-edge"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "013bb586-6e44-4aa2-b903-702dab8fc3f5"
      }
    }
  }
}

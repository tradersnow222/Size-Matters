# Copy to .env (gitignored) and fill in real values.
# Also set these as EAS environment variables for builds.

# RevenueCat publishable SDK keys (safe to ship client-side)
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=appl_xxxxxxxx
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=goog_xxxxxxxx
EXPO_PUBLIC_REVENUECAT_TEST_KEY=test_xxxxxxxx

# AI providers (used by src/lib/fishEditor.ts).
# NOTE: EXPO_PUBLIC_* values are bundled into the app and are extractable.
# For production, move these behind a backend proxy (see CLAUDE.md).
# Gemini "Nano Banana" — detection + PRIMARY resize (https://aistudio.google.com/apikey)
# NOTE: image models are PAID-tier — enable billing on the key's Google project.
EXPO_PUBLIC_GEMINI_API_KEY=AIza_xxxxxxxx
# FLUX — fallback resize engine (only used when RESIZE_PROVIDER='flux')
EXPO_PUBLIC_FLUX_API_KEY=bfl_xxxxxxxx

# Backend proxy (../../proxy). Empty = direct-to-Google. Set after deploying the Worker to move
# keys server-side (then the AI keys above are no longer needed in the client).
EXPO_PUBLIC_PROXY_URL=
EXPO_PUBLIC_PROXY_SECRET=
